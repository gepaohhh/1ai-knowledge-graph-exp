#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Aqueduct
                :CheckDam
                :Culvert
                :FermentationCellar
                :FloodDetentionArea
                :HydropowerStation
                :InvertedSiphon
                :IrrigationDistrict
                :Levee
                :Polder
                :PondDam
                :PumpingStation
                :Reservoir
                :ReservoirDam
                :RiverRegulationProject
                :RubberDam
                :RuralWaterSupplyProject
                :Sluice
                :WaterDiversionProject
                :WaterWell
                <http://www.semanticweb.org/lenovo/ontologies/2026/3/FloodControlDispatchOntology#Canal(Ditch)>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Basin
                :Lake
                :River
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :DischargeOutlet
                :LeveeSection
                :RiverLakeManagementScope
                :RiverReach
                :SandMiningZone
                :ShorelineFunctionZone
                :SoilConservationZoning
                :VulnerableSection
                :WastewaterDischarger
                :WaterFunctionZone
                :WaterIntake
                :WaterResourceZone
                :WaterSourceArea
                :WaterUser
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :HydrologicalStation
                :SoilConservationStation
                :WaterQuantityMonitoringPoint
                :WaterVideoSurveillancePoint
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :MonitoringStationPoint
                :OtherManagementObject
                :RiverAndLakes
                :WaterConservancyProject
              )
] .


